{
  "name": "mygames",
  "private": true,
  "description": "A monorepo for browser games — one folder, many games, shared tools.",
  "workspaces": [
    "games/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "play": "node scripts/play.mjs",
    "start": "node scripts/launch.mjs",
    "launch": "node scripts/launch.mjs",
    "status": "node scripts/launch.mjs --status",
    "family": "node scripts/family-play.mjs",
    "play:br2": "node scripts/play-one.mjs babys-revenge-2",
    "play:car": "node scripts/play-one.mjs car-crashing-with-dashing",
    "car": "node scripts/teleport.mjs car-crashing-with-dashing",
    "teleport:car": "node scripts/teleport.mjs car-crashing-with-dashing",
    "games": "node scripts/games-hub.mjs",
    "start-all": "node scripts/start-all-games.mjs",
    "restore": "node scripts/launch.mjs",
    "serve": "node scripts/serve-docs.mjs",
    "stop": "node scripts/stop.mjs",
    "family:br2": "npm run family -- babys-revenge-2",
    "family:car": "npm run family -- car-crashing-with-dashing",
    "share-link": "node scripts/share-link.mjs",
    "turn-on-link": "node scripts/turn-on-link.mjs",
    "build": "node scripts/build.mjs",
    "build:all": "node scripts/build.mjs --all",
    "new-game": "node scripts/new-game.mjs",
    "list-games": "node scripts/list-games.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
